# LinkedIn Daily Posts Pipeline - Environment Configuration Template
# Copy this file to .env and fill in your credentials
# IMPORTANT: Do NOT commit .env to git - it contains secrets!

# ============================================================================
# REQUIRED: Zernio API Configuration
# ============================================================================

# Your Zernio API key (get from https://zernio.com)
ZERNIO_API_KEY=your_zernio_api_key_here

# Zernio API base URL (usually this default)
ZERNIO_BASE_URL=https://zernio.com/api/v1

# Your LinkedIn account ID in Zernio dashboard
LINKEDIN_ACCOUNT_ID=your_account_id_here

# ============================================================================
# OPTIONAL: OpenRouter API Configuration (for production content generation)
# ============================================================================

# Your OpenRouter API key (get from https://openrouter.io)
# If not set, pipeline uses demo mode with realistic test posts
# OPENROUTER_API_KEY=sk-or-v1-your_key_here

# ============================================================================
# OPTIONAL: Application Configuration
# ============================================================================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Environment: local, staging, production
ENVIRONMENT=local
